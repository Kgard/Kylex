---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Showcase from '../components/Showcase.astro';
import Pricing from '../components/Pricing.astro';
import ProAccess from '../components/ProAccess.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Lodestar — Keep the flow state. Even when the session ends." description="Every AI coding tool remembers what you built. None of them remember why. Lodestar commits your reasoning to your repo. Free forever.">
  <Nav />
  <main>
    <Hero />
    <Problem />
    <HowItWorks />
    <Showcase />
    <Pricing />
    <ProAccess />
  </main>
  <Footer />
</Layout>
