---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Showcase from '../components/Showcase.astro';
import Pricing from '../components/Pricing.astro';
import ProAccess from '../components/ProAccess.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Lodestar — Every session remembers where you left off" description="Lodestar captures your AI coding session context and synthesizes it into a portable .lodestar.md for warm cold-starts. Free forever.">
  <Nav />
  <main>
    <Hero />
    <Problem />
    <HowItWorks />
    <Showcase />
    <Pricing />
    <ProAccess />
  </main>
  <Footer />
</Layout>
