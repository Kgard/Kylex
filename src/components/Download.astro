---
---

<section id="download" class="py-20 px-6 bg-slate-50">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-[#0C447C] mb-4">Get Lodestar</h2>
    <p class="text-slate-500 mb-10">Install in under a minute. No account, no email, no sign-up.</p>

    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="text-sm font-medium text-[#0C447C] mb-3">Binary</div>
        <div class="font-mono text-xs bg-slate-900 text-green-400 px-3 py-2 rounded-lg">
          curl -fsSL kylex.io/install | sh
        </div>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="text-sm font-medium text-[#0C447C] mb-3">npm</div>
        <div class="font-mono text-xs bg-slate-900 text-green-400 px-3 py-2 rounded-lg">
          npm install -g lodestar
        </div>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <div class="text-sm font-medium text-[#0C447C] mb-3">Homebrew</div>
        <div class="font-mono text-xs bg-slate-900 text-green-400 px-3 py-2 rounded-lg">
          brew install lodestar
        </div>
      </div>
    </div>

    <div class="max-w-md mx-auto bg-white rounded-xl border border-slate-200 p-6">
      <p class="text-sm text-slate-500 mb-3">Stay updated on releases — optional</p>
      <form class="flex gap-2" id="download-newsletter">
        <input type="email" placeholder="you@example.com" class="flex-1 px-4 py-2.5 text-sm border border-slate-200 rounded-lg focus:outline-none focus:border-[#185FA5] focus:ring-1 focus:ring-[#185FA5]" />
        <button type="submit" class="px-5 py-2.5 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors">Subscribe</button>
      </form>
      <p class="text-xs text-slate-400 mt-2">No spam, ever. Unsubscribe anytime.</p>
    </div>
  </div>
</section>
