---

<section id="pro" class="py-20 px-6">
  <div class="max-w-lg mx-auto text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-[#0C447C] mb-4">Lodestar Pro Early Access</h2>
    <p class="text-slate-500 mb-8">Be first to know pricing and get the founding member rate. Cross-device sync, multi-project intelligence, full suite access.</p>

    <form class="space-y-4" id="pro-signup">
      <input type="email" placeholder="you@example.com" required class="w-full px-4 py-3 text-sm border border-slate-200 rounded-lg focus:outline-none focus:border-[#185FA5] focus:ring-1 focus:ring-[#185FA5]" />
      <label class="flex items-start gap-2 text-left">
        <input type="checkbox" class="mt-1 rounded border-slate-300 text-[#185FA5] focus:ring-[#185FA5]" />
        <span class="text-xs text-slate-500">Also send me Lodestar release notes and product updates.</span>
      </label>
      <button type="submit" class="w-full px-6 py-3 bg-[#185FA5] text-white font-medium rounded-lg hover:bg-[#0C447C] transition-colors">
        Join Early Access
      </button>
    </form>

    <div class="mt-6 p-4 bg-[#E6F1FB] rounded-lg">
      <p class="text-xs text-[#0C447C]">Your email is used for Lodestar updates only. Never sold. Never shared. Unsubscribe anytime.</p>
    </div>
  </div>
</section>
